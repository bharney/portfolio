		"mini-css-extract-plugin": "^2.10.2",
		"node-noop": "1.0.0",
		"nodemon": "^3.1.14",
		"postcss-import": "^16.1.1",
		"postcss-loader": "^8.2.1",
		"prettier": "^3.8.1",
		"react-refresh": "^0.18.0",
		"rimraf": "^6.1.3",
