{
	"name": "portfolio",
	"version": "1.0.0",
	"description": "bharney.com website for portfolio, blogging, and about me.",
	"main": "./dist/app.js",
	"author": "bharney0",
	"license": "MIT",
	"sideEffects": [
		"*.css",
		"*.scss"
	],
	"scripts": {
		"start": "node ./dist/app.js",
		"test:client": "npx jest",
		"build": "cross-env NODE_ENV=production npx webpack --env PRODUCTION",
		"start:client": "npx webpack serve --config-name client --env HOT",
		"start:server": "npx webpack && npx concurrently \"npx webpack -w\" \"npx nodemon --delay 2 --watch dist/app.js --watch dist/public/index.html dist/app.js\"",
		"lint": "eslint src/",
		"pre-push": "npm run lint && npm run test",
		"pre-commit-prettier": "pretty-quick --staged --pattern \"**/*.{scss,ts,js,json,yml}\"",
		"prettier": "prettier --write \"**/*.{scss,ts,js,json,yml}\"",
		"prettier-check": "prettier --check \"**/*.{scss,ts,js,json,yml}\"",
		"images:webp": "npx ts-node scripts/convert-to-webp.ts",
		"images:parallax": "npx ts-node scripts/generate-parallax-variants.ts",
		"analyze": "npx webpack --env PRODUCTION --env ANALYZE"
	},
	"dependencies": {
		"@fortawesome/fontawesome-svg-core": "^7.2.0",
		"@fortawesome/free-brands-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@fortawesome/react-fontawesome": "^3.3.0",
		"@reduxjs/toolkit": "^2.11.2",
		"bootstrap": "^5.3.8",
		"compression": "^1.8.1",
		"express": "^5.2.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-redux": "^9.2.0",
		"react-router-dom": "^7.14.0"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/plugin-transform-runtime": "^7.29.0",
		"@babel/preset-env": "^7.29.2",
		"@babel/preset-react": "^7.28.5",
		"@babel/preset-typescript": "^7.28.5",
		"@babel/runtime": "^7.29.2",
		"@fullhuman/postcss-purgecss": "^7.0.2",
		"@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
		"@types/compression": "^1.8.1",
		"@types/express": "^5.0.6",
		"@types/jest": "^29.5.14",
		"@types/jsdom": "^21.1.7",
		"@types/node": "^22.19.17",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/supertest": "^6.0.3",
		"@types/webpack": "^5.28.5",
		"@types/webpack-bundle-analyzer": "^4.7.0",
		"@types/webpack-dev-server": "^4.7.2",
		"@types/webpack-env": "^1.18.8",
		"autoprefixer": "^10.4.27",
		"babel-loader": "^9.2.1",
		"babel-plugin-lodash": "^3.3.4",
		"clean-webpack-plugin": "^4.0.0",
		"concurrently": "^9.2.1",
		"copy-webpack-plugin": "^14.0.0",
		"cross-env": "^10.1.0",
		"css-loader": "^7.1.4",
		"css-minimizer-webpack-plugin": "^8.0.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jest": "^29.15.2",
